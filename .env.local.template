# Copy this file to .env.local and fill in values from each provider's dashboard.
# NEVER put real values in this template or commit .env.local to git.

# Supabase — https://supabase.com/dashboard → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Anthropic — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Stripe — https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create these in Stripe Dashboard → Products
STRIPE_PRICE_FOUNDER=       # £7.99/month recurring (Founder Rate)
STRIPE_PRICE_STANDARD=      # £12.99/month recurring (Standard)
STRIPE_PRICE_ANNUAL=        # £99/year recurring (Annual)
STRIPE_PRICE_SCHOOL_SMALL=  # £299/year (School Small)
STRIPE_PRICE_SCHOOL_MEDIUM= # £499/year (School Medium)

# App
NEXT_PUBLIC_APP_URL=https://guidedchildhood.com

# Social media law config — drives Stage 4 content and DiGi without a code rewrite
# Values: none | partial_ban | full_ban_u16
# Current UK state (June 2026): full ban confirmed, Regulations end 2026, live Spring 2027
# Switch to full_ban_u16 when the ban goes live (Spring 2027)
NEXT_PUBLIC_SOCIAL_MEDIA_LAW=partial_ban

# Optional: override the banned platform list (comma-separated, no spaces)
# Default: Instagram,YouTube,TikTok,Snapchat,Facebook,X
# Update when UK Regulations finalise the platform list
# BANNED_PLATFORMS=Instagram,YouTube,TikTok,Snapchat,Facebook,X

# DiGi model — defaults to claude-fable-5, swappable without a redeploy
DIGI_MODEL=claude-fable-5
