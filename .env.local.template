# Copy this file to .env.local and fill in values from each provider's dashboard.
# NEVER put real values in this template or commit .env.local to git.
# Keys go from provider website into Vercel env vars only. Never into chat, email, or code.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Dashboard → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── Anthropic ───────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — dashboard.stripe.com → Products → click product → copy price ID
STRIPE_PRICE_FOUNDER=        # £7.99/month recurring (Founder Rate, capped at 50)
STRIPE_PRICE_STANDARD=       # £12.99/month recurring (Standard)
STRIPE_PRICE_ANNUAL=         # £99/year recurring (Annual)
STRIPE_PRICE_SCHOOL_SMALL=   # £299/year (School Small, up to 200 pupils)
STRIPE_PRICE_SCHOOL_MEDIUM=  # £499/year (School Medium, 200+ pupils)

# ─── App ─────────────────────────────────────────────────────────────────────
# Platform lives at app.guidedchildhood.com — separate Vercel project from the static site
NEXT_PUBLIC_APP_URL=https://app.guidedchildhood.com

# ─── Social media law ────────────────────────────────────────────────────────
# Drives Stage 4 DiGi content and scripts without a code rewrite.
# Values: none | partial_ban | full_ban_u16
# UK state June 2026: ban confirmed, Regulations live Spring 2027
# Switch to full_ban_u16 when the ban goes live
NEXT_PUBLIC_SOCIAL_MEDIA_LAW=partial_ban

# Optional — override the default banned platform list (comma-separated, no spaces)
# Default: Instagram,YouTube,TikTok,Snapchat,Facebook,X
# Update when UK Regulations publish the final platform list
# BANNED_PLATFORMS=Instagram,YouTube,TikTok,Snapchat,Facebook,X

# ─── DiGi ────────────────────────────────────────────────────────────────────
# Swappable without a redeploy. Default is claude-fable-5.
# Fallback chain in lib/config/digi.ts: claude-fable-5 → claude-opus-4-8 → claude-sonnet-4-6
DIGI_MODEL=claude-fable-5

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# resend.com → API Keys. Without a key every send is a logged no-op, so the
# app runs fine in dev and email switches on when the key lands in Vercel.
RESEND_API_KEY=
# The from address. Domain must be verified in Resend first.
EMAIL_FROM="Justin at Guided Childhood <hello@guidedchildhood.co.uk>"

# ─── Cron ────────────────────────────────────────────────────────────────────
# Shared secret for Vercel Cron calls to /api/push/cron and /api/email/cron.
# Vercel sends it automatically as the Authorization header when set.
CRON_SECRET=
