{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "agents.html",
      "use": "@vercel/static"
    },
    {
      "src": "digitalwellbeing/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/digitalwellbeing",
      "dest": "/digitalwellbeing/index.html"
    },
    {
      "src": "/digitalwellbeing/",
      "dest": "/digitalwellbeing/index.html"
    },
    {
      "src": "/agents",
      "dest": "/agents.html"
    },
    {
      "src": "/agents/",
      "dest": "/agents.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
