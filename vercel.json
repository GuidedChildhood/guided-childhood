    { "src": "/GC-Module9-Worksheet/", "dest": "/GC-Module9-Worksheet.html" },
    { "src": "/GC-Module9-TeacherNotes", "dest": "/GC-Module9-TeacherNotes.html" },
    { "src": "/GC-Module9-TeacherNotes/", "dest": "/GC-Module9-TeacherNotes.html" },
    { "src": "/GC-Module9-FeedbackSheet", "dest": "/GC-Module9-FeedbackSheet.html" },
