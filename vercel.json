    { "src": "/scripts/", "dest": "/scripts.html" },
    { "src": "/trust", "dest": "/trust.html" },
    { "src": "/trust/", "dest": "/trust.html" },
    { "src": "/evidence", "dest": "/evidence.html" },
    { "src": "/evidence/", "dest": "/evidence.html" },
    { "src": "/join", "status": 302, "headers": { "Location": "https://mailchi.mp/thesocialbillboard/parents" } },
    { "src": "/join/", "status": 302, "headers": { "Location": "https://mailchi.mp/thesocialbillboard/parents" } },
