{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["lhr1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/starter-pack", "destination": "/starter-pack" }
  ],
  "crons": [
    { "path": "/api/push/cron", "schedule": "*/30 * * * *" },
    { "path": "/api/push/reengage", "schedule": "0 17 * * *" },
    { "path": "/api/school/remind", "schedule": "0 18 * * *" },
    { "path": "/api/email/cron", "schedule": "0 8 * * *" },
    { "path": "/api/cron/digi-insights", "schedule": "0 7 * * *" }
  ]
}
