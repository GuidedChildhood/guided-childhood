    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/GC-Module9-SocialMediaBrain-KS3.pptx",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.openxmlformats-officedocument.presentationml.presentation" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"GC-Module9-SocialMediaBrain-KS3.pptx\"" }
      ]
    },
    {
      "source": "/evidence-paper.pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"The-Social-Media-Ban-Evidence-Review-2026.pdf\"" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
