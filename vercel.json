{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["lhr1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/starter-pack", "destination": "/starter-pack" }
  ],
  "crons": [
    { "path": "/api/cron/device-time", "schedule": "* * * * *" },
    { "path": "/api/push/cron", "schedule": "*/30 * * * *" },
    { "path": "/api/push/reengage", "schedule": "0 17 * * *" },
    { "path": "/api/school/remind", "schedule": "0 18 * * *" },
    { "path": "/api/school/morning", "schedule": "45 6 * * *" },
    { "path": "/api/email/cron", "schedule": "0 8 * * *" },
    { "path": "/api/cron/age-up", "schedule": "30 5 * * *" },
    { "path": "/api/cron/digi-insights", "schedule": "0 7 * * *" },
    { "path": "/api/cron/digi-wisdom", "schedule": "0 6 * * 0" },
    { "path": "/api/cron/digi-quality", "schedule": "30 6 * * 1" },
    { "path": "/api/cron/weekly-review", "schedule": "45 18 * * 0" },
    { "path": "/api/cron/settings-nudge", "schedule": "0 10 * * 3" },
    { "path": "/api/cron/knowledge-refresh", "schedule": "0 6 1,15 * *" },
    { "path": "/api/cron/script-refresh", "schedule": "0 7 1,15 * *" },
    { "path": "/api/cron/lesson-drip", "schedule": "0 9 1,15 * *" }
  ]
}
