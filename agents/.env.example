# Guided Childhood agents — environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# In GitHub, add the same keys as repository Secrets (Settings -> Secrets ->
# Actions) so the workflows can read them.

# Anthropic / Claude API key — required for all agents.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail SMTP credentials for sending the briefing email.
# GMAIL_APP_PASSWORD is a 16-char Google "App Password" (not your login
# password). Create one at https://myaccount.google.com/apppasswords with
# 2-Step Verification enabled.
GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Optional: override the briefing recipient (defaults to
# justin@thesocialbillboard.com inside the code).
# BRIEFING_RECIPIENT=justin@thesocialbillboard.com
